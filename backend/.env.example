# === DATABASE (PostgreSQL) ===
DATABASE_URL=postgresql://postgres:password@localhost:5432/adaptive_learning

# === NEO4J (Graph Database) ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# === JWT Security ===
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# === AI/LLM (Get free key from https://console.groq.com) ===
GROQ_API_KEY=your-groq-api-key-here

# === Frontend URL (for production CORS) ===
FRONTEND_URL=
